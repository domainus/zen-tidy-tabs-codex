[
  {
    "type": "checkbox",
    "label": "Enable Firefox local AI",
    "property": "browser.ml.enabled",
    "force": true,
    "defaultValue": true
  },
  {
    "type": "dropdown",
    "label": "Tidy provider",
    "property": "zen-tidy-tabs.provider",
    "defaultValue": "local",
    "options": [
      {
        "label": "Firefox local AI",
        "value": "local"
      },
      {
        "label": "Codex CLI (installed + logged in)",
        "value": "codex"
      },
      {
        "label": "OpenAI-compatible API",
        "value": "openai"
      },
      {
        "label": "Heuristics only",
        "value": "heuristic"
      }
    ]
  },
  {
    "type": "string",
    "label": "OpenAI-compatible base URL",
    "property": "zen-tidy-tabs.openai.baseUrl",
    "defaultValue": "https://api.openai.com/v1"
  },
  {
    "type": "string",
    "label": "OpenAI-compatible model",
    "property": "zen-tidy-tabs.openai.model",
    "defaultValue": "gpt-4.1-mini"
  },
  {
    "type": "string",
    "label": "OpenAI-compatible API key",
    "property": "zen-tidy-tabs.openai.apiKey",
    "defaultValue": ""
  },
  {
    "type": "checkbox",
    "label": "Send URL paths to remote APIs / Codex CLI (hostnames are always included)",
    "property": "zen-tidy-tabs.openai.sendPaths",
    "defaultValue": false
  },
  {
    "type": "string",
    "label": "Codex CLI path",
    "property": "zen-tidy-tabs.codex.path",
    "defaultValue": "/opt/homebrew/bin/codex"
  },
  {
    "type": "string",
    "label": "Codex model override (optional)",
    "property": "zen-tidy-tabs.codex.model",
    "defaultValue": ""
  },
  {
    "type": "string",
    "label": "Codex timeout seconds",
    "property": "zen-tidy-tabs.codex.timeoutSeconds",
    "defaultValue": "90"
  },
  {
    "type": "separator",
    "label": "Tidy Downloads"
  },
  {
    "property": "extensions.downloads.mistral_api_key",
    "label": "Mistral API key for AI-powered download renaming",
    "type": "string",
    "placeholder": "Enter your Mistral API key here"
  },
  {
    "property": "extensions.downloads.mistral_model",
    "label": "Mistral model",
    "type": "dropdown",
    "placeholder": "Select model",
    "defaultValue": "mistral-small-latest",
    "options": [
      {
        "label": "Mistral Small",
        "value": "mistral-small-latest"
      },
      {
        "label": "Mistral Medium",
        "value": "mistral-medium-latest"
      },
      {
        "label": "Mistral Large",
        "value": "mistral-large-latest"
      }
    ]
  },
  {
    "type": "separator",
    "label": "Download Behavior"
  },
  {
    "property": "extensions.downloads.enable_ai_renaming",
    "type": "checkbox",
    "label": "Enable AI-powered file renaming",
    "defaultValue": true
  },
  {
    "property": "zen-tidy-tabs.downloads.showCustomUi",
    "type": "checkbox",
    "label": "Show custom Tidy Downloads UI/pods (disable to keep only smart file renaming)",
    "defaultValue": false
  },
  {
    "type": "dropdown",
    "label": "Tidy Downloads rename provider",
    "property": "zen-tidy-tabs.downloads.provider",
    "defaultValue": "codex",
    "options": [
      {
        "label": "Codex CLI (content-aware)",
        "value": "codex"
      },
      {
        "label": "Mistral API (upstream)",
        "value": "mistral"
      }
    ]
  },
  {
    "property": "zen-tidy-tabs.downloads.contentMaxBytes",
    "type": "string",
    "label": "Max text bytes to inspect for content-based download names",
    "defaultValue": "12000"
  },
  {
    "type": "separator",
    "label": "Debugging"
  },
  {
    "property": "extensions.downloads.enable_debug",
    "type": "checkbox",
    "label": "Enable debugging logs in browser console (Ctrl + Shift + J)",
    "defaultValue": false
  },
  {
    "property": "extensions.downloads.debug_ai_only",
    "type": "checkbox",
    "label": "Show only AI renaming debug logs (requires debug enabled)",
    "defaultValue": true
  }
]
